// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// -------------------- Shopify Session --------------------

model Session {
  id                  String    @id @map("_id")
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// -------------------- Plans --------------------
// Numeric _id preserved to keep existing PLAN_IDS constants valid.

model Plan {
  id           Int      @id @map("_id")
  name         String
  description  String?
  monthlyPrice Float    @default(0)
  yearlyPrice  Float    @default(0)
  currency     String   @default("USD")
  features     String[]
  featureKeys  String[] @default([])
  usageLimit   Int      @default(0)
  trialDays    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// -------------------- Shop --------------------

type ShopPermissions {
  skinEnabled Boolean @default(true)
  hairEnabled Boolean @default(true)
}

type ShopSettingsEmbed {
  appEmbedEnabled Boolean @default(false)
  isCustomized    Boolean @default(false)
}

type ShopSubscription {
  id           String?
  planId       Int       @default(1)
  interval     String?   // "month" | "year" — which billing cadence the merchant chose
  status       String?
  activatedAt  DateTime?
  cancelledAt  DateTime?
  trialEndsAt  DateTime?
  trialUsed    Boolean   @default(false)
}

type ShopUsage {
  count            Float     @default(0)
  periodStart      DateTime  @default(now())
  limitNotifiedAt  DateTime?
}

model Shop {
  id             String             @id @default(auto()) @map("_id") @db.ObjectId
  shop           String             @unique
  accessToken    String?
  ownerEmail     String?
  ownerName      String?
  isInstalled    Boolean            @default(false)
  installedAt    DateTime           @default(now())
  permissions    ShopPermissions
  settings       ShopSettingsEmbed
  subscription   ShopSubscription
  usage          ShopUsage
  uninstalledAt  DateTime?
  appSettings    Settings?
}

// -------------------- Settings --------------------

type WidgetConfig {
  position    String @default("bottom-right")
  buttonText  String @default("Analyze Skin")
  bgColor     String @default("#0084ff")
  textColor   String @default("#ffffff")
  fontSize    Int    @default(16)
  fontWeight  String @default("normal")
  paddingX    Int    @default(24)
  paddingY    Int    @default(12)
  radius      Int    @default(30)
}

// Per-element text styling inside a chat bubble. The bubble has a heading
// row and a text row; each gets its own font + spacing controls.
type BubbleText {
  fontSize     Int    @default(14)
  fontWeight   String @default("normal")
  color        String @default("#333333")
  marginTop    Int    @default(0)
  marginRight  Int    @default(0)
  marginBottom Int    @default(0)
  marginLeft   Int    @default(0)
}

// Chat-bubble card: only carries card-level styling (background + radius).
// Text styling lives on the inner heading/text blocks.
type BubbleConfig {
  bgColor String     @default("#f4f4f4")
  radius  Int        @default(12)
  heading BubbleText
  text    BubbleText
}

type DrawerHeader {
  label      String @default("Label Text")
  fontFamily String @default("sans-serif")
  fontSize   Int    @default(18)
  fontWeight String @default("normal") 
  textColor  String @default("#ffffff")
  bgColor    String @default("#0084ff")
}

type DrawerBubbles {
  boat BubbleConfig 
  user BubbleConfig
}

type DrawerConfig {
  bgColor String         @default("#ffffff")
  header  DrawerHeader
  bubble  DrawerBubbles
}

type ModuleImage {
  url    String @default("")
  height Int    @default(50)
  width  Int    @default(50)
  radius Int    @default(15)
}

type SkinModuleText {
  label      String @default("Skin Analysis")
  textColor  String @default("#333333")
  fontSize   Int    @default(14)
  fontWeight String @default("normal")
}

type HairModuleText {
  label      String @default("Hair Analysis")
  textColor  String @default("#333333")
  fontSize   Int    @default(14)
  fontWeight String @default("normal")
}

type SkinModuleConfig {
  enabled Boolean        @default(true)
  text    SkinModuleText
  image   ModuleImage
}

type HairModuleConfig {
  enabled Boolean        @default(true)
  text    HairModuleText
  image   ModuleImage
}

type SettingsModules {
  skinCare SkinModuleConfig
  hairCare HairModuleConfig
}

model Settings {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  shopId    String          @unique @db.ObjectId
  shop      Shop            @relation(fields: [shopId], references: [id])
  widget    WidgetConfig
  drawer    DrawerConfig
  modules   SettingsModules
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

// -------------------- Customers --------------------

model Customer {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  shopId            String   @db.ObjectId
  shopifyCustomerId String
  email             String?
  firstName         String?
  lastName          String?
  totalScans        Float    @default(0)
  orderCount        Int      @default(0)
  totalSpend        Float    @default(0)
  currency          String?
  lastAnalysisAt    DateTime?
  lastOrderAt       DateTime?
  dailyScanCount    Float    @default(0)
  dailyScanResetAt  DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shopId, shopifyCustomerId])
  @@index([shopId, lastAnalysisAt])
}

// ------------------ AI Activity/Sessions  ----------------------

model AiSession {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  shopId            String    @db.ObjectId
  customerId        String    @db.ObjectId
  externalSessionId String?
  flowType          String?
  status            String    @default("started") // started | completed | abandoned
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([shopId, customerId, startedAt])
  @@index([externalSessionId])
}

// ------------------ Orders ----------------------

model Orders {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  shopId            String    @db.ObjectId
  customerId        String    @db.ObjectId
  shopifyOrderId    String
  orderNumber       String?
  externalSessionId String?
  totalPrice        Float     @default(0)
  currency          String?
  lineItemCount     Int       @default(0)
  fulfillmentStatus String?
  financialStatus   String?
  placedAt          DateTime
  createdAt         DateTime  @default(now())

  @@unique([shopId, shopifyOrderId])
  @@index([shopId, customerId, placedAt])
}

