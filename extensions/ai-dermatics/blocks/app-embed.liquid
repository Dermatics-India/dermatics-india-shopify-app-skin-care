
{% if customer %}
  <script>
    window.DERMA_AI_APP_ASSETS = {
      reportIcon: "{{ 'report-icon.png' | asset_url }}",
      downloadIcon: "{{ 'download-icon.png' | asset_url }}",
      sendMsgIcon: "{{ 'send-msg-icon.png' | asset_url }}",
      aiIcon: "{{  'ai-icon.png' | asset_url }}"

    }
    window.DERMA_AI_CUSTOMER = {
      id: {{ customer.id | json }},
      email: {{ customer.email | json }},
      firstName: {{ customer.first_name | json }},
      lastName: {{ customer.last_name | json }},
    };
  </script>
{% else %}
  <script>
    window.DERMA_AI_CUSTOMER = null;
  </script>
{% endif %}

<link rel="stylesheet" href="{{ 'derma-ai.css' | asset_url }}">
<script src="{{ 'derma-ai.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "AI Embed",
  "target": "body",
  "settings": []
}
{% endschema %}
